# Airtable — airtable.com/create/tokens
# Scopes: data.records:read, data.records:write
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXX

# Gmail OAuth2 — console.cloud.google.com
# 1. Create OAuth2 credentials (Web Application)
# 2. Add redirect URI: https://developers.google.com/oauthplayground
# 3. Enable Gmail API
# 4. Use OAuth Playground to get refresh token with gmail.send + gmail.readonly scopes
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REFRESH_TOKEN=1//xxxxx
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground

# Your sending email (display purposes + from header)
SMTP_EMAIL=brandon@tradecafe.ai
SMTP_NAME=Brandon @ TradeCafe

# GitHub — github.com/settings/tokens
GITHUB_TOKEN=ghp_XXXXXXXXX

# Hunter.io — hunter.io/api-keys (optional)
HUNTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Discord — reply alerts + cron summaries (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Vercel Cron auth (optional)
CRON_SECRET=your-random-secret
